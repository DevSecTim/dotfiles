# ~/.ssh/config
# Managed by dotfiles — machine-specific hosts go in ~/.config/ssh_config.d/
Include ~/.config/ssh_config.d/*

# Global defaults
Host *
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 60
    ServerAliveCountMax 3

# Alias: Tims-Mac-mini
Host mac-mini tims-mac-mini.angler-pancake.ts.net
    HostName tims-mac-mini.angler-pancake.ts.net
    IdentityFile ~/.ssh/id_ed25519.personal
    User tim

# Alias: Tims-MacBook-Air
Host macbook-air tims-macbook-air.angler-pancake.ts.net
    HostName tims-macbook-air.angler-pancake.ts.net
    IdentityFile ~/.ssh/id_ed25519.personal
    User tim

# Alias: Tims-Syne-MacBook
Host syne-macbook tims-syne-macbook.angler-pancake.ts.net
    HostName tims-syne-macbook.angler-pancake.ts.net
    IdentityFile ~/.ssh/id_ed25519.synechron
    User timjones
